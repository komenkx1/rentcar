# ==========================================
# Database (Self-Hosted PostgreSQL)
# ==========================================
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# Local Docker/Coolify example:
DATABASE_URL="postgresql://rentcar_user:rentcar_password@postgres:5432/rentcar?schema=public"

# Direct connection for migrations (optional, fallback to DATABASE_URL if not set)
# Use this if DATABASE_URL points to a connection pooler (e.g., PgBouncer)
# DIRECT_URL="postgresql://rentcar_user:rentcar_password@postgres:5432/rentcar?schema=public"

# ==========================================
# S3-Compatible Object Storage (MinIO)
# ==========================================
# S3 endpoint URL (internal/server-side). Works with MinIO.
S3_ENDPOINT="http://localhost:9000"

# S3 region (usually us-east-1 for MinIO)
S3_REGION="us-east-1"

# S3 credentials (server-side only, never expose to client)
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"

# S3 bucket name
S3_BUCKET="rentcar"

# Force path-style URLs (required for MinIO)
S3_FORCE_PATH_STYLE="true"

# Public base URL for browser access (image display)
# This is usually different from S3_ENDPOINT when behind reverse proxy
S3_PUBLIC_BASE_URL="http://localhost:9000/rentcar"

# ==========================================
# Telegram Bot (Notifications)
# ==========================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_ADMIN_CHAT_ID=your_admin_chat_id

# ==========================================
# Resend (Email)
# ==========================================
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL=rentcars@yourdomain.com

# ==========================================
# App Configuration
# ==========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=rentCars

# Cron secret (for protecting cron endpoints)
CRON_SECRET=your_random_secret_string

# ==========================================
# Mock DB (set to true for development without database)
# ==========================================
NEXT_PUBLIC_MOCK_DB=true
